<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@android:color/white"
    android:gravity="center_horizontal">

    <androidx.cardview.widget.CardView
        android:id="@+id/cv_ad_container_native"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@+id/layout"
        android:layout_marginTop="@dimen/_5sdp"
        android:visibility="visible"
        app:cardBackgroundColor="@android:color/transparent"
        app:cardCornerRadius="@dimen/_6sdp"
        app:cardElevation="0dp">

        <com.facebook.shimmer.ShimmerFrameLayout
            android:id="@+id/loading_layout_native"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_gravity="center"
            android:gravity="center"
            android:orientation="horizontal"
            android:padding="@dimen/_1sdp">

            <include
                layout="@layout/full_screen_native"
                android:visibility="visible" />

        </com.facebook.shimmer.ShimmerFrameLayout>
    </androidx.cardview.widget.CardView>

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:id="@+id/layout"
        android:layout_marginTop="@dimen/_10sdp"
        android:background="#A98AE4"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent">

        <ImageView
            android:id="@+id/imgStart"
            android:layout_width="50dp"
            android:layout_height="30dp"
            android:layout_alignParentStart="true"
            android:layout_centerVertical="true"
            android:rotation="180"
            android:layout_marginStart="16dp"
            android:src="@android:drawable/arrow_down_float"
            app:tint="@color/white" />

        <ImageView
            android:id="@+id/imgEnd"
            android:layout_width="50dp"
            android:layout_height="30dp"
            app:tint="@color/white"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:layout_marginEnd="16dp"
            android:src="@android:drawable/arrow_down_float" />

        <TextView
            android:id="@+id/text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_toEndOf="@id/imgStart"
            android:layout_toStartOf="@id/imgEnd"
            android:layout_centerVertical="true"
            android:gravity="center"
            android:textSize="@dimen/_13sdp"
            android:paddingVertical="12dp"
            android:text="@string/swipe_to_next"
            android:textColor="@color/white"
            android:fontFamily="sans-serif-medium"/>

    </RelativeLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
